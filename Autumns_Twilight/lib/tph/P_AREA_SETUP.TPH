      fj_info_point_strref  = RESOLVE_STR_REF(@200078)    // Una enorme cantidad de huesos y cadáveres de ganado se encuentra en este rincón. El hedor te inunda los pulmones al tiempo en que las moscas danzan sobre la sangre. Te preguntas quién o qué es el autor de tal masacre.
      fj_vertex_0       = 1243 + (1038 << 16)
      fj_vertex_1       = 1381 + (929 << 16)
      fj_vertex_2       = 1458 + (976 << 16)
      fj_vertex_3       = 1285 + (1086 << 16)
      STR_VAR
