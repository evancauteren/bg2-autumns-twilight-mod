      fj_box_top        = 48
      fj_box_right      = 2351
      fj_box_bottom     = 276
      fj_cursor_idx     = 22      // info cursor
      fj_info_point_strref  = RESOLVE_STR_REF(@200079)    // Es imposible atisbar la oscuridad de esta cueva. No ves nada. No oyes nada. Sólo percibes una profunda maldad más allá de la honda negrura de telarañas.
      fj_vertex_0       = 2206 + (219 << 16)
      fj_vertex_1       = 2351 + (276 << 16)
      fj_vertex_2       = 2350 + (48 << 16)
      fj_vertex_3       = 2266 + (50 << 16)
      STR_VAR
