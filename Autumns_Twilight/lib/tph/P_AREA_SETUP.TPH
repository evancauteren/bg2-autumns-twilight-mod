// P_AREA_SETUP
// Chequea mod Hidden Adventures -> Temple of Mask
ACTION_IF !FILE_EXISTS_IN_GAME ~RRSPMASK.CRE~
THEN BEGIN
COPY_EXISTING ~ar0300.are~ ~override~
    LPF fj_are_structure
      INT_VAR
      fj_loc_x          = 992
      fj_loc_y          = 1367
      fj_note_strref    = RESOLVE_STR_REF(@400455)    // Mathyus's Hideout
      STR_VAR
      fj_structure_type = note
    END
// Travel region: to p_ar14
    LPF fj_are_structure
      INT_VAR
      fj_type           = 2         // travel trigger
      fj_box_left       = 982
      fj_box_top        = 1348
      fj_box_right      = 1007
      fj_box_bottom     = 1433
	  fj_cursor_idx     = 42        // cursor
      fj_flags          = (1 << 2)  // [Party required]      
      fj_loc_x          = 1010
      fj_loc_y          = 1419
	  //fj_alt posiblemente sea necesario. Poner similar/mayor en el "y" valor
	  fj_alt_x          = 3485
      fj_alt_y          = 1395
      fj_vertex_0       = 982 + (1389 << 16)
      fj_vertex_1       = 1003 + (1348 << 16)
      fj_vertex_2       = 1007 + (1393 << 16)
      fj_vertex_3       = 988 + (1433 << 16)      
      STR_VAR
      fj_structure_type   = region
      fj_name             = P_travel_to_p_ar14
      fj_destination_area = P_AR14
      fj_destination_name = P_ENTRANCE1
    END
    // Entrance: from Hideout
    LPF fj_are_structure
      INT_VAR
      fj_loc_x          = 994
      fj_loc_y          = 1398
      fj_orientation    = 12    // E
      STR_VAR
      fj_structure_type = entrance
      fj_name           = P_ENTRANCEAR0300
    END	
END


COPY_EXISTING ~ar0404.are~ ~override~
    LPF fj_are_structure
      INT_VAR
      fj_loc_x          = 2598
      fj_loc_y          = 1220
      fj_note_strref    = RESOLVE_STR_REF(@200072)    // Beyond Sewers
      STR_VAR
      fj_structure_type = note
    END
// Travel region: to P_FAR1
    LPF fj_are_structure
      INT_VAR
      fj_type           = 2         // travel trigger
      fj_box_left       = 2483
      fj_box_top        = 1137
      fj_box_right      = 2694
      fj_box_bottom     = 1295
	  fj_cursor_idx     = 42        // cursor
      fj_flags          = (1 << 2)  // [Party required]
	  // Launching Point
      fj_loc_x          = 3485
      fj_loc_y          = 1380
	  // Operating Point
	  fj_alt_x          = 3485
      fj_alt_y          = 1395
      fj_vertex_0       = 2483 + (1155 << 16)
      fj_vertex_1       = 2663 + (1295 << 16)
      fj_vertex_2       = 2694 + (1271 << 16)
      fj_vertex_3       = 2517 + (1137 << 16)      
      STR_VAR
