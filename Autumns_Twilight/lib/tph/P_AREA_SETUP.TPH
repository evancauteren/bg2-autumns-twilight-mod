      fj_destination_area = P_FAR1
      fj_destination_name = P_f1e1
	  //fj_reg_script = P_TEST
    END

    // Entrance: from Beyond
    LPF fj_are_structure
      INT_VAR
      fj_loc_x          = 2584
      fj_loc_y          = 1217
      fj_orientation    = 2    // SW
      STR_VAR
      fj_structure_type = entrance
      fj_name           = P_F1E4
    END

