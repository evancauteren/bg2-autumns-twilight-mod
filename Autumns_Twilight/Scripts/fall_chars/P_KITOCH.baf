// Kitochi habla sobre Gorm (Kitochi Vive)
IF
  //InParty(Myself)
  Global ("P_FallAboutGormsDeath_KitAlive","GLOBAL",0)
  AreaCheck("P_FAR4")
  Dead("P_GORM")
  PartyHasItem("p_hgormu")
  CombatCounter(0)
  See("P_Fall")
THEN
  RESPONSE #100
  SetGlobal ("P_FallAboutGormsDeath_KitAlive","GLOBAL",1)
  StartDialogNoSet(Player1)
END

