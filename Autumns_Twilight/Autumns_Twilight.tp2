SAY SELECT_COMMON6 @700022 /* Siempre sÃĐ vigilante. */
SAY SELECT_ACTION1 @700023 /* Hm.  */
SAY SELECT_ACTION2 @700024 /* Soy el Maestro de la Escarcha... esta tarea no es digna de mÃ­. */
SAY SELECT_ACTION3 @700025 /* SÃĐ respetuoso... o de lo contrario congelarÃĐ tu corazÃģn. */
SAY SELECT_ACTION4 @700026 /* El conocimiento es lo mÃĄs importante. La fuerza bruta es intracendente. */
SAY SELECT_ACTION5 @700027 /* Estoy convencido de que interactuar con un gÃģlem es mÃĄs interesante que esto. */
SAY SELECT_ACTION6 @700028 /* Estoy sobrecalificado para esto. */
SAY SELECT_ACTION7 @700029 /* Lo harÃĐ y quedarÃĄs conforme. */
SAY SELECT_RARE1 @700030 /* Asumo que responder ante ti es mejor que responder ante Cryonax. */
SAY SELECT_RARE2 @700031 /* Debo admitirlo: eres un mejor aliado que Icelock. */
SAY CRITICAL_HIT @700032 /* ÂĄEvereska! */
SAY CRITICAL_MISS @700033 /* Esta no es mi principal habilidad. */
SAY TARGET_IMMUNE @700034 /* Mejor piensa en otra soluciÃģn, joven. */
SAY INVENTORY_FULL @700035 /* Me debes haber confundido con una mula de carga. Tus cosas ahora yacen en el suelo. */ 
SAY SPELL_DISRUPTED @700036 /* ÂĄHmpf! Han interrumpido mi sortilegio. */
