PRINT ~Installing Dusk, The Wizardslayer~
COPY ~Autumns_Twilight/Characters/cre_and_portraits/P_Dusk.cre~ ~override/P_Dusk.cre~
SAY NAME1 @4002 /* Dusk */
SAY NAME2 @4002 /* Dusk */
SAY INITIAL_MEETING @4003 /* Mis oïŋ―dos aïŋ―n retumban con esa explosiïŋ―n... */ 
SAY MORALE @4004 /* ïŋ―No...!,ïŋ―ïŋ―ïŋ―NO!!! */
