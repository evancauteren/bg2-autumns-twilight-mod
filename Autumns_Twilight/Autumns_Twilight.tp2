// Hidden Adventures -> Mask Temple (Tweak) detected
// RRSPMASK
ACTION_IF FILE_EXISTS_IN_GAME ~RRSPMASK.CRE~
THEN BEGIN
  PRINT ~Hidden Adventures -> Mask Temple (Tweak) detected~
  PRINT ~Adding crossmod~
COPY ~Autumns_Twilight/Scripts/crossmod/hidden_adventures~ ~override~
//EXTEND_TOP ~AR0300.bcs~ ~Autumns_Twilight/Scripts/crossmod/hidden_adventures/AR0300.baf~

COMPILE ~%MOD_FOLDER%/Scripts/crossmod/hidden_adventures/P_BR14.are~
COMPILE ~%MOD_FOLDER%/Scripts/crossmod/hidden_adventures/P_BR14.baf~
// P_AR14
  COPY_EXISTING ~P_BR14.are~ ~override~
  READ_LONG 0xbc song_offset
  WRITE_LONG song_offset ~%P_G1%~	//day song
  WRITE_LONG song_offset+0x4 ~%P_G1%~ //night song

COPY_EXISTING ~P_BR14.are~ ~override~
	LPF fj_are_structure
      INT_VAR
      fj_loc_x          = 1142
      fj_loc_y          = 1143
      fj_note_strref    = RESOLVE_STR_REF(@400465)    // Temple of Mask
      STR_VAR
      fj_structure_type = note
    END
	
COPY_EXISTING ~JA#D00.are~ ~override~
    LPF fj_are_structure
      INT_VAR
      fj_loc_x          = 415
      fj_loc_y          = 96
      fj_note_strref    = RESOLVE_STR_REF(@400455)    // Mathyus's Hideout
      STR_VAR
      fj_structure_type = note
    END
    LPF fj_are_structure
      INT_VAR
      fj_loc_x          = 677
      fj_loc_y          = 267
      fj_note_strref    = RESOLVE_STR_REF(@400456)    // Docks
      STR_VAR
      fj_structure_type = note
    END
	SAY 0x354 ~<NO TEXT>~
END



