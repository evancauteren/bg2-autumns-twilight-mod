SAY MORALE @4004 /* ïŋ―No...!,ïŋ―ïŋ―ïŋ―NO!!! */
SAY HAPPY @4005 /* Me gusta cïŋ―mo este grupo maneja las cosas. */ 
SAY UNHAPPY_ANNOYED @4006 /* Deberïŋ―amos reconsiderar nuestras acciones... */ 
SAY UNHAPPY_SERIOUS @4007 /* Claramente algo no funciona aquïŋ―... */
SAY UNHAPPY_BREAKING @4008 /* No podemos seguir trabajando juntos... */
SAY LEADER @4009 /* Te prefiero a ti como lïŋ―der, pero si insistes... */
SAY TIRED @40010 /* *bostezo* Creo que necesitamos descansar, ïŋ―no lo crees? */
SAY BORED @40011 /* No importa lo lento que vayas mientras no te detengas... */
SAY BATTLE_CRY1 @40012 /* ïŋ―Veamos lo que tienes! */
