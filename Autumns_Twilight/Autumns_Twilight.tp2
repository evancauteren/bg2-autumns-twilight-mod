SAY DAMAGE ~~ [P_Dusk19]
SAY DYING ~~ [P_Dusk20]
SAY HURT @40015 /* Lo lamento... necesito a alguien que se ocupe de mis heridas. */
SAY AREA_FOREST @40016 /* Debemos cuidarnos de las bestias salvajes. Por mïŋ―s hermoso que sea el bosque, el peligro se encuentra a la vuelta de la esquina... */  // If there's no sound file for the line, then it's going to be silent.
SAY AREA_CITY @40017 /* Es increïŋ―ble cïŋ―mo la corrupciïŋ―n ha invadido hasta el rincïŋ―n mïŋ―s recïŋ―ndito de la ciudad... */
SAY AREA_DUNGEON @40018 /* Debes tener cuidado aquïŋ―. Presiento... peligro. */
SAY AREA_DAY @40019 /* Hoy es un buen dïŋ―a para pasear. Pero recuerda, <CHARNAME>, que tenemos un deber que cumplir. */
SAY AREA_NIGHT @40020 /* Las estrellas brillan en el firmamento, pero ïŋ―cuidado! No todo lo que brilla es oro... All that is gold does not glitter*/
SAY SELECT_COMMON1 @40021 /* ïŋ―Quïŋ― tienes en mente? */
SAY SELECT_COMMON2 @40022 /* ïŋ―Sïŋ―? */
SAY SELECT_COMMON3 @40023 /* ïŋ―Quïŋ― quieres? */
SAY SELECT_COMMON4 @40039 /* Te protegerïŋ―. */
SAY SELECT_COMMON5 @40040 /* Hola, extraïŋ―o. */
SAY SELECT_COMMON6 @40046 /* Recuerda: nadie te golpearïŋ― tan fuerte como la vida misma. */
SAY SELECT_ACTION1 @40024 /* ïŋ―Muy bien! */
SAY SELECT_ACTION2 @40025 /* Sïŋ―, sïŋ―. No necesitas gritar. */
SAY SELECT_ACTION3 @40026 /* Hmmm... sïŋ―, ïŋ―por quïŋ― no? */
SAY SELECT_ACTION4 @40027 /* Te seguirïŋ―. */
SAY SELECT_ACTION5 @40028 /* Una vez mïŋ―s... */
SAY SELECT_ACTION6 @40029 /* Dïŋ―jamelo a mïŋ―. */
SAY SELECT_ACTION7 @40030 /* ïŋ―Serïŋ― rïŋ―pido al respecto! */
SAY SELECT_RARE1 @40031 /* Hmm... ïŋ―te conozco? ïŋ―Ja! Sïŋ―lo bromeo. */
SAY SELECT_RARE2 @40032 /* Agradezco la atenciïŋ―n, pero ïŋ―no deberïŋ―amos centrarnos en el asunto que nos ocupa? */
SAY CRITICAL_HIT @40047 /* ïŋ―ïŋ―ïŋ―Sïŋ―!!! */
SAY CRITICAL_MISS @40034 /* Argh! */
SAY TARGET_IMMUNE @40048 /* *suspiro* Mi objetivo es inmune... */
SAY INVENTORY_FULL @40036 /* Lo siento, pero mi mochila estïŋ― llena. */ 
SAY SPELL_DISRUPTED @40037 /* ïŋ―Estoy malherido! */
SAY REACT_TO_DIE_GENERAL @40045 /*  */ // Reacciïŋ―n a la muerte de un compaïŋ―ero de grupo
SAY PICKED_POCKET @40051 /* Vaya... le he robado... */
SAY HIDDEN_IN_SHADOWS @40041 /* Shhh... ahora estoy en las sombras... */
SAY SET_A_TRAP @40050 /* *risa* La trampa... ha sido puesta. */
SAY BIO @40038 /* Cuando preguntas por su pasado, Dusk queda un instante pensativo. Dice provenir de una orgullosa familia real, cuya sangre guerrera siempre combatiïŋ― a los malvados nigromantes de Netheril, incluyendo al peligroso Aumvor. Dusk dice no estar seguro de la veracidad de ciertas narraciones que le contaron cuando era sïŋ―lo un niïŋ―o, pero estïŋ― seguro de su odio natural por los liches. Dice que te acompaïŋ―arïŋ― siempre y cuando estïŋ― la promesa de que podrïŋ― enfrentarse, algïŋ―n dïŋ―a, contra lo que ïŋ―l considera sus enemigos naturales. */
WRITE_ASCII 0x248 ~P_Dus25S~ #8 
WRITE_ASCII 0x2cc ~P_Dusk25~ #8 
