BACKUP ~Autumns_Twilight/Backup~ 

AUTHOR ~Pol Rupes - pablo.alejandro.ramos@gmail.com~ 

VERSION ~v1.4.5~

README ~Autumns_Twilight/Readme-Autumns_Twilight.txt~

//PRINT ~AUTO_TRA~ ERROR

AUTO_TRA ~Autumns_Twilight/tra/%s~ 
ALWAYS
  INCLUDE ~%MOD_FOLDER%/lib/a7#add_kit_ex.tpa~
  INCLUDE ~%MOD_FOLDER%/lib/alter_script.tpa~
  INCLUDE ~%MOD_FOLDER%/lib/functions.tph~
  ACTION_IF NOT VARIABLE_IS_SET bg2_chapter BEGIN
    ACTION_IF GAME_IS ~eet~ BEGIN
      OUTER_SET bg2_chapter = 12 
    END ELSE BEGIN
      OUTER_SET bg2_chapter = 0 
    END
    OUTER_FOR (i=1; i<=10; i=i+1) BEGIN
      OUTER_SET bg2_chapter = bg2_chapter + 1
      OUTER_SPRINT name_source ~bg2_chapter_%i%~
      OUTER_SET EVAL ~%name_source%~ = bg2_chapter
    END
  END

ACTION_DEFINE_ARRAY 9xnoconvert BEGIN END 

ACTION_DEFINE_ARRAY 9xreload BEGIN setup END 

/*  LAF HANDLE_CHARSETS
    INT_VAR
      infer_charsets = 1
	  //auto_utf8 = 1
    STR_VAR
      tra_path = EVAL ~%MOD_FOLDER%/tra~
      noconvert_array = 9xnoconvert
      reload_array = 9xreload
END

*/

END

// PRINT ~Languages~ ERROR
LANGUAGE ~Spanish~ ~Spanish~ ~Autumns_Twilight/tra/Spanish/setup.tra~
LANGUAGE ~English~ ~English~ ~Autumns_Twilight/tra/English/setup.tra~
LANGUAGE ~Italian (Not fully accurate)~ ~Italian~ ~Autumns_Twilight/tra/Italian/setup.tra~
LANGUAGE ~German (Not fully accurate)~ ~German~ ~Autumns_Twilight/tra/German/setup.tra~
LANGUAGE ~Polish (Not fully accurate)~ ~Polish~ ~Autumns_Twilight/tra/Polish/setup.tra~
LANGUAGE ~French (Not fully accurate)~ ~French~ ~Autumns_Twilight/tra/French/setup.tra~
LANGUAGE ~Russian (Not fully accurate)~ ~Russian~ ~Autumns_Twilight/tra/Russian/setup.tra~
LANGUAGE ~Simplified Chinese by ghostcat~ ~schinese~ ~Autumns_Twilight/tra/schinese/setup.tra~






BEGIN @1 /* Autumn's Twilight */ 

ACTION_IF NOT FILE_EXISTS_IN_GAME ~P_WGUACL.2da~ THEN BEGIN
    PRINT ~Installing New Animations~
    INCLUDE ~%MOD_FOLDER%/lib/wildguard.tpa~    
    INCLUDE ~%MOD_FOLDER%/lib/frostmast.tpa~
    
    PRINT ~Installing Kits: Twilight Blade...~
    INCLUDE ~%MOD_FOLDER%/lib/twilightblade.tpa~
    
    PRINT ~Installing Kits: Shadow Slinger...~
    INCLUDE ~%MOD_FOLDER%/lib/shadowslinger.tpa~
    
    PRINT ~Installing Kits: Hybrid Agent...~
    INCLUDE ~%MOD_FOLDER%/lib/hybridagent.tpa~
    
    PRINT ~Installing Kits: Mistweaver...~
    INCLUDE ~%MOD_FOLDER%/lib/dreamwalker.tpa~
    
    PRINT ~Installing Kits: Mirror Blade...~
    INCLUDE ~%MOD_FOLDER%/lib/mirrorblade.tpa~
    
    PRINT ~Installing Kits: Dwarven Artificer...~
    INCLUDE ~%MOD_FOLDER%/lib/dwarvenartificer.tpa~
END


APPEND ~STATE.IDS~ ~0x80101FEF CD_STATE_NOTVALID~
UNLESS ~CD_STATE_NOTVALID~

