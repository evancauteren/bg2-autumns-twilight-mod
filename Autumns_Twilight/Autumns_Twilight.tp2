SAY PICKED_POCKET @700040 /* I'm not proud of it, but I got away with it. */
SAY HIDDEN_IN_SHADOWS @700040 /* Like a shadow, I disappear. */
SAY SET_A_TRAP @700040 /* Ha! Let's see them try and get past that now. */
SAY BIO @700038 /* Cuando preguntas por su pasado, ALENDIR cuenta con orgullo que proviene de una noble lÃ­nea de descendencia de Altos Elfos de Cormanthyr y (siempre que puede) te recuerda lo afortunado que eres de que te estÃĐ acompaÃąando en tus insulsas aventuras. No habla mucho mÃĄs de sus experiencias personales, excepto de lo peligroso que fue entrenarse como Maestro de la Escarcha en el Reino Oculto. Si bien Alendir es anciano, bien sabes que los elfos rara vez demuestran facciones de decrepitud. No fue el caso de Alendir, ya que su entrenamiento en el FrÃ­o de Cryonax le costÃģ su energÃ­a vital, a cambio de obtener un poder absoluto en el Plano Paraelemental del Hielo. Luego de su muerte a manos de Icelock, el mismo fue revivido por Vidomina, una poderosa hechicera de FalcongrÃ­s. Alendir tiene ahora otra oportunidad de redimir sus ambiciosos actos arcanos a tu lado.  */
WRITE_ASCII 0x248 ~P_AlenS~ #8  // OVERRIDE SCRIPT - Scripts acerca de los comandos, banthers, etc (coincide con el nombre del archivo BAF)
WRITE_ASCII 0x2cc ~P_Alen~  #8  // DIALOGUE FILE - Archivo de saludo de Fall
WRITE_ASCII 0x280 ~P_Alen~  #32 // DEATH VARIABLE - Hace referencia a c?mo nos referimos a Fall en el juego. (Ej.: In Party (P_Fall))
WRITE_ASCII 0x34  ~P_ALEN~ #8  // small portrait
WRITE_ASCII 0x3c  ~P_ALENL~ #8  // medium portrait
WRITE_SHORT 0x246 (IDS_OF_SYMBOL (~kit~ ~P_FMAS~))
